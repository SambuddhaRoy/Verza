<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher icon foreground — "The Fold" mark, inset.

  The mark is geometrically centred at (256, 256), but it's top-heavy (wide pages up
  top tapering to a point at the bottom), so its *optical* centre sits above the middle
  and the logo read as sitting too high. The whole mark is nudged down 30 viewport units
  via the wrapping <group> so it reads as vertically balanced inside the safe zone.

  Base geometry (computed from the original 512-space SVG by scale = 0.65 around centre):
    Left page:  131,143 → 217,143 → 253,369 → 256,369
    Right page: 381,143 → 295,143 → 259,369 → 256,369
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <group android:translateY="30">

        <!-- Left page (ink). Inner-50 % version. -->
        <path
            android:fillColor="#0C0C0C"
            android:pathData="M 131,143 L 217,143 L 253,369 L 256,369 Z"/>

        <!-- Right page (ink). Mirror of the left. -->
        <path
            android:fillColor="#0C0C0C"
            android:pathData="M 381,143 L 295,143 L 259,369 L 256,369 Z"/>

        <!--
          Suggestion-of-text lines. Same proportions to each page as the original, scaled
          with the rest.
        -->
        <path
            android:strokeColor="#F5F1EA"
            android:strokeWidth="1.0"
            android:strokeAlpha="0.25"
            android:pathData="
                M 145,158 L 194,158
                M 143,166 L 190,166
                M 143,175 L 192,175
                M 145,183 L 195,183
                M 318,158 L 367,158
                M 322,166 L 369,166
                M 320,175 L 369,175
                M 317,183 L 367,183"/>
    </group>
</vector>
