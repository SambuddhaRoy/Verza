<?xml version="1.0" encoding="utf-8"?>
<!--
  Certificate array required by the Compose Google Fonts provider.
  The string-array com_google_android_gms_fonts_certs is declared by
  the androidx.compose.ui:ui-text-google-fonts library at runtime via
  its bundled resources. This file is a local alias so the R.array
  reference in Type.kt resolves at compile time.
-->
<resources>
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>
    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item></item>
    </string-array>
    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item></item>
    </string-array>
</resources>
